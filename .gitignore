# Dependencies
node_modules/
backend/node_modules/

# Build outputs
dist/
dist-ssr/
backend/dist/

# Environment variables
.env
.env.local
.env.*.local
backend/.env
backend/.env.local
backend/.env.*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Prisma generated client
backend/node_modules/.prisma/

# OS files
.DS_Store
Thumbs.db

# Editor files
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.sw?

# Testing
coverage/
backend/coverage/

# Misc
*.local
*.tsbuildinfo

# ── Terraform ─────────────────────────────────────────
.terraform/              # downloaded providers (like node_modules)
.terraform.lock.hcl      # can be committed, but optional
*.tfstate                # STATE FILE — contains real infrastructure details, never commit
*.tfstate.backup         # backup of state file
terraform.tfvars         # contains secrets — never commit
*.generated.yml          # generated files
*.generated              # generated files
