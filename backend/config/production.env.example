# Production Environment
# Used on the live server
# Real users, real data, real M-Pesa transactions
# NEVER put actual values here — this file is committed to git
# Actual values live in GitHub Secrets and on the server only

NODE_ENV=production
PORT=3001
API_URL=https://api.yourdomain.com
FRONTEND_URL=https://yourdomain.com

# Production PostgreSQL — managed database recommended
DATABASE_URL=postgresql://postgres:CHANGE_ME@prod-db-host:5432/memberhub

# JWT — must be long random strings in production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING
JWT_REFRESH_SECRET=CHANGE_ME_ANOTHER_LONG_RANDOM_STRING
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Redis
REDIS_HOST=prod-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME

# M-Pesa — LIVE credentials in production
MPESA_CONSUMER_KEY=CHANGE_ME
MPESA_CONSUMER_SECRET=CHANGE_ME
MPESA_SHORT_CODE=YOUR_ACTUAL_SHORTCODE
MPESA_PASSKEY=CHANGE_ME
MPESA_CALLBACK_URL=https://api.yourdomain.com/api/payments/mpesa/callback
MPESA_ENV=production

# Logging — warnings and errors only in production
LOG_LEVEL=warn
LOG_FILE_PATH=./logs

# Rate limiting — strict in production
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
