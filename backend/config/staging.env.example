# Staging Environment
# Used on the staging server
# Real server, but fake data — safe to test and break

NODE_ENV=staging
PORT=3001
API_URL=https://staging-api.yourdomain.com
FRONTEND_URL=https://staging.yourdomain.com

# Staging PostgreSQL server
DATABASE_URL=postgresql://postgres:CHANGE_ME@staging-db-host:5432/memberhub_staging

# JWT — use a real random string on staging
JWT_SECRET=CHANGE_ME_TO_RANDOM_STRING
JWT_REFRESH_SECRET=CHANGE_ME_TO_ANOTHER_RANDOM_STRING
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Redis on staging server
REDIS_HOST=staging-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME

# M-Pesa — still use sandbox on staging
MPESA_CONSUMER_KEY=CHANGE_ME
MPESA_CONSUMER_SECRET=CHANGE_ME
MPESA_SHORT_CODE=174379
MPESA_PASSKEY=CHANGE_ME
MPESA_CALLBACK_URL=https://staging-api.yourdomain.com/api/payments/mpesa/callback
MPESA_ENV=sandbox

# Logging — less verbose on staging
LOG_LEVEL=info
LOG_FILE_PATH=./logs

# Rate limiting — same as production
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
