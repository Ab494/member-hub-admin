# Development Environment
# Used on your local machine
# Copy to backend/.env when developing locally

NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001
FRONTEND_URL=http://localhost:8080

# Local PostgreSQL (via Docker)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/memberhub

# JWT — any string is fine for local dev
JWT_SECRET=dev-secret-not-for-production
JWT_REFRESH_SECRET=dev-refresh-secret-not-for-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Redis (via Docker)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# M-Pesa — use sandbox in development
MPESA_CONSUMER_KEY=sandbox-key
MPESA_CONSUMER_SECRET=sandbox-secret
MPESA_SHORT_CODE=174379
MPESA_PASSKEY=sandbox-passkey
MPESA_CALLBACK_URL=http://localhost:3001/api/payments/mpesa/callback
MPESA_ENV=sandbox

# Logging — verbose in development
LOG_LEVEL=debug
LOG_FILE_PATH=./logs

# Rate limiting — relaxed in development
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
